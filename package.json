{
  "name": "cursor-boston",
  "version": "0.1.0",
  "description": "A modern community platform for Cursor users in the Boston area. Built with Next.js, TypeScript, and Firebase.",
  "license": "GPL-3.0-only",
  "homepage": "https://github.com/rogerSuperBuilderAlpha/cursor-boston#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/rogerSuperBuilderAlpha/cursor-boston.git"
  },
  "bugs": {
    "url": "https://github.com/rogerSuperBuilderAlpha/cursor-boston/issues"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "cursor",
    "boston",
    "community",
    "nextjs",
    "next.js",
    "firebase",
    "typescript",
    "react",
    "tailwindcss",
    "community-platform",
    "meetup",
    "events",
    "blog",
    "authentication",
    "firestore"
  ],
  "scripts": {
    "dev": "NODE_OPTIONS='--no-deprecation' next dev --webpack -H localhost",
    "build": "next build --webpack",
    "start": "NODE_OPTIONS='--no-deprecation' next start",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test": "jest --config config/jest.config.js",
    "test:rules": "firebase emulators:exec --only firestore \"npm test -- --runTestsByPath __tests__/config/firebase/firestore.rules.test.ts --testPathIgnorePatterns='^$'\"",
    "test:watch": "jest --watch --config config/jest.config.js",
    "test:coverage": "jest --coverage --config config/jest.config.js",
    "validate-env": "tsx scripts/validate-env.ts",
    "seed-hackathon-teams": "tsx scripts/seed-hackathon-teams.ts",
    "check-members-db": "tsx scripts/check-members-db.ts",
    "rate-limit-cleanup": "tsx scripts/run-rate-limit-cleanup.ts",
    "backfill-merge-credit": "tsx scripts/backfill-merge-credit.ts",
    "send-hack-a-sprint-emails": "tsx scripts/send-hack-a-sprint-emails.ts",
    "sync-event-contacts": "tsx scripts/sync-event-contacts.ts",
    "send-contact-list-email": "tsx scripts/send-contact-list-email.ts",
    "ai-evaluate": "tsx scripts/ai-evaluate-submissions.ts",
    "distribute-credits": "tsx scripts/distribute-cursor-credits.ts",
    "seed-luma-registrants": "tsx scripts/seed-luma-registrants.ts",
    "generate-contributors": "bash scripts/generate-contributors.sh",
    "prebuild": "npm run validate-env",
    "prepare": "husky install",
    "add:gpl-headers": "node scripts/add-gpl-headers.js",
    "analyze": "ANALYZE=true next build"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "firebase": "^12.12.0",
    "firebase-admin": "^13.8.0",
    "form-data": "^4.0.5",
    "gray-matter": "^4.0.3",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.8.0",
    "mailgun.js": "^12.7.1",
    "next": "^16.2.3",
    "next-themes": "^0.4.6",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-leaflet": "^5.0.0",
    "react-leaflet-cluster": "^4.1.3",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "recharts": "^3.8.1",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/compat": "^2.0.5",
    "@eslint/eslintrc": "^3.3.5",
    "@firebase/rules-unit-testing": "^5.0.0",
    "@next/bundle-analyzer": "^16.2.3",
    "@next/eslint-plugin-next": "^16.2.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/jest": "^30.0.0",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.5.2",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "eslint": "^10.2.0",
    "eslint-config-next": "^16.2.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "firebase-tools": "^15.14.0",
    "globals": "^17.5.0",
    "husky": "^8.0.3",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.7.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  },
  "overrides": {
    "typescript-eslint": "^8.58.0",
    "eslint-plugin-import": {
      "eslint": "$eslint"
    },
    "eslint-plugin-jsx-a11y": {
      "eslint": "$eslint"
    },
    "eslint-plugin-react": {
      "eslint": "$eslint"
    },
    "eslint-plugin-react-hooks": {
      "eslint": "$eslint"
    },
    "@typescript-eslint/eslint-plugin": {
      "eslint": "$eslint"
    },
    "@typescript-eslint/parser": {
      "eslint": "$eslint"
    },
    "@typescript-eslint/utils": {
      "eslint": "$eslint"
    },
    "@typescript-eslint/type-utils": {
      "eslint": "$eslint"
    },
    "react-leaflet": {
      "react": "$react",
      "react-dom": "$react-dom"
    },
    "@react-leaflet/core": {
      "react": "$react",
      "react-dom": "$react-dom"
    },
    "react-leaflet-cluster": {
      "react": "$react",
      "react-dom": "$react-dom"
    },
    "http-proxy-agent": "^7.0.0"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "bash -c 'tsc --noEmit'"
    ],
    "**/*.{js,jsx,ts,tsx}": [
      "eslint --fix --max-warnings=0"
    ]
  }
}
