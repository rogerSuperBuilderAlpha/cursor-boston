# =============================================================================
# Zero-Config Demo Environment
# =============================================================================
# Copy this file to .env.local for instant local development:
#
#   cp .env.local.demo .env.local
#   npm run dev
#
# The site loads and renders fully — layouts, pages, styling all work.
# Firebase-dependent features (auth, data, storage) are gracefully disabled.
#
# For full functionality, see docs/DEVELOPMENT.md for Firebase setup options:
#   - Option A: Firebase Emulator (no cloud account needed)
#   - Option B: Personal Firebase project
# =============================================================================

# Firebase Configuration (demo values — passes validation, skips SDK init)
NEXT_PUBLIC_FIREBASE_API_KEY=demo-api-key-not-real
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=demo-cursor-boston.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=demo-cursor-boston
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=demo-cursor-boston.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:demo000000000000
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://demo-cursor-boston-default-rtdb.firebaseio.com
