{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cursorboston.com/schemas/hack-a-sprint-2026-submission.json",
  "title": "Hack-a-Sprint 2026 submission",
  "type": "object",
  "additionalProperties": false,
  "required": ["projectRepoUrl", "deployedUrl", "title", "description", "loomVideoUrl"],
  "properties": {
    "projectRepoUrl": {
      "type": "string",
      "format": "uri",
      "description": "Public GitHub repo URL for the hack project"
    },
    "deployedUrl": {
      "type": "string",
      "format": "uri",
      "description": "Live demo / deployment URL"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 8000
    },
    "loomVideoUrl": {
      "type": "string",
      "format": "uri",
      "description": "Loom (or similar) URL of you explaining the project"
    },
    "demoVideoUrl": {
      "type": "string",
      "format": "uri"
    }
  }
}
